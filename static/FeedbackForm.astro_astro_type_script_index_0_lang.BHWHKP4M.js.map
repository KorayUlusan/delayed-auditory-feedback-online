  import { initForm } from '@formspree/ajax';

  document.addEventListener("DOMContentLoaded", () => {
    const stars = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".rating-stars .star"),
    );
    const ratingInput = document.getElementById("ratingInput") as HTMLInputElement;
    const fsError = document.getElementById("fs-error");
    const form = document.getElementById("ratingForm") as HTMLFormElement;

    // Initialize Formspree AJAX
    initForm({
      formElement: '#ratingForm',
      formId: 'meepwrew',
    });

    // Star Rating UI Logic
    const setStars = (n: number) => {
      stars.forEach((s, i) => {
        const isFilled = i < n;
        // Uses the .filled class defined in your CSS
        s.classList.toggle("filled", isFilled);
        s.textContent = isFilled ? "★" : "☆";
        s.setAttribute("aria-checked", isFilled ? "true" : "false");
      });
      if (ratingInput) ratingInput.value = String(n);
      
      // Clear manual validation error if user picks a star
      if (fsError) {
        fsError.textContent = "";
        fsError.style.display = "none";
      }
    };

    const highlightHover = (n: number) => {
      stars.forEach((s, i) => s.classList.toggle("hover", i < n));
    };

    const clearHover = () => stars.forEach((s) => s.classList.remove("hover"));

    stars.forEach((btn, i) => {
      btn.addEventListener("click", () => setStars(i + 1));
      btn.addEventListener("mouseenter", () => highlightHover(i + 1));
      btn.addEventListener("mouseleave", clearHover);
      btn.addEventListener("focus", () => highlightHover(i + 1));
      btn.addEventListener("blur", clearHover);
    });

    // Custom validation to ensure a rating is selected
    form?.addEventListener("submit", (e) => {
      if (!ratingInput?.value) {
        e.preventDefault();
        e.stopImmediatePropagation();
        
        if (fsError) {
          fsError.textContent = "Please select a star rating before submitting.";
          fsError.style.display = "block";
        }
      }
    });
  });


