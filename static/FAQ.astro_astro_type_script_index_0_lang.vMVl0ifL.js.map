  // FAQ accordion — each .faq-question h3 toggles its answer div.
  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll<HTMLElement>(".faq-question")
      .forEach((q) => {
        const answer = q.closest("[itemscope]")?.querySelector(".faq-answer") as HTMLElement | null;
        if (!answer) return;

        answer.style.display = "none";
        q.setAttribute("aria-expanded", "false");
        q.setAttribute("role", "button");
        q.setAttribute("tabindex", "0");

        const toggle = () => {
          const open = answer.style.display !== "none";
          answer.style.display = open ? "none" : "block";
          q.classList.toggle("active", !open);
          q.setAttribute("aria-expanded", String(!open));
          window.sendAnalyticsEvent?.("faq_interaction", {
            faq_question: q.textContent,
          });
        };

        q.addEventListener("click", toggle);
        q.addEventListener("keydown", (e: KeyboardEvent) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            toggle();
          }
        });
      });

    // "Show more / Hide" toggle
    const btn = document.getElementById("faqToggle");
    const more = document.getElementById("moreFaq");
    if (!btn || !more) return;

    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      more.hidden = expanded;
      btn.setAttribute("aria-expanded", String(!expanded));
      btn.textContent = expanded ? "Show more FAQs" : "Hide extra FAQs";
    });
  });


